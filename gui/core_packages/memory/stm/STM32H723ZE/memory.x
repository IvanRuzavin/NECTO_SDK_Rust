/* memory.x - Linker script for the STM32H723ZE */
MEMORY
{
  ITCMRAM    : ORIGIN = 0x00000000,   LENGTH = 64K
  DTCMRAM    : ORIGIN = 0x20000000,   LENGTH = 128K
  FLASH    : ORIGIN = 0x08000000,   LENGTH = 512K
  RAM_D1    : ORIGIN = 0x24000000,   LENGTH = 320K
  RAM_D2    : ORIGIN = 0x30000000,   LENGTH = 32K
  RAM_D3    : ORIGIN = 0x38000000,   LENGTH = 16K
}
