/* memory.x - Linker script for the STM32H7B3LI */
MEMORY
{
  ITCMRAM  : ORIGIN = 0x00000000, LENGTH = 64K
  FLASH     : ORIGIN = 0x08000000, LENGTH = 2048K
  DTCMRAM1 : ORIGIN = 0x20000000, LENGTH = 64K
  DTCMRAM2 : ORIGIN = 0x20010000, LENGTH = 64K
  RAM      : ORIGIN = 0x24000000, LENGTH = 1024K
  RAM_CD   : ORIGIN = 0x30000000, LENGTH = 128K
  RAM_SRD  : ORIGIN = 0x38000000, LENGTH = 32K
}
