/* memory.x - Linker script for the STM32H7S3R8 */
MEMORY
{
  RAM : ORIGIN = __RAM_BEGIN,    LENGTH = __RAM_SIZE
  RAM_NONCACHEABLEBUFFER : ORIGIN = __RAM_BEGIN + __RAM_SIZE,  LENGTH = __RAM_NONCACHEABLEBUFFER_SIZE

  ITCM : ORIGIN = 0x00000000,    LENGTH = 0x00010000
  DTCM : ORIGIN = 0x20000000,    LENGTH = 0x00010000
  SRAMAHB  : ORIGIN = 0x30000000,  LENGTH = 0x00008000
  BKPSRAM  : ORIGIN = 0x38800000,  LENGTH = 0x00001000

  FLASH : ORIGIN = __FLASH_BEGIN, LENGTH = __FLASH_SIZE
}
